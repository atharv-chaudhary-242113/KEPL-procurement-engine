# =========================
# 1. Rust & Cargo
# =========================
/target/
**/*.rs.bk
Cargo.lock.workspace

# Note on 'vendor/':
# If you want to keep the repository lightweight, uncomment the line below
# and run `cargo vendor` locally after every clone.
# If you want true "offline sovereignty" stored permanently on GitHub, leave it commented so the vendor code is committed.
vendor/
.cargo/config.toml

